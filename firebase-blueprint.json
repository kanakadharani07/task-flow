{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public user profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "avatar": { "type": "string", "description": "URL to profile image" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "System role" },
        "bio": { "type": "string", "description": "Short user biography" },
        "createdAt": { "type": "string", "format": "date-time", "description": "User registration timestamp" }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task created by a user.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Task title" },
        "description": { "type": "string", "description": "Task description" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"], "description": "Task progress status" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "Task priority level" },
        "dueDate": { "type": "string", "format": "date-time", "description": "Task deadline" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "List of tags" },
        "category": { "type": "string", "description": "Task category (e.g., Work, Personal)" },
        "userId": { "type": "string", "description": "UID of the task creator" },
        "assignedTo": { "type": "string", "description": "UID of the user assigned to this task" },
        "attachments": { "type": "array", "items": { "type": "string" }, "description": "URLs to attached files" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["title", "status", "priority", "userId", "createdAt", "updatedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Alert for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Recipient user ID" },
        "message": { "type": "string", "description": "Notification message text" },
        "read": { "type": "boolean", "description": "Read status" },
        "type": { "type": "string", "description": "Notification type (e.g., deadline, assign)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Notification timestamp" }
      },
      "required": ["userId", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public profile for each user."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Global tasks collection."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System-wide notifications."
    }
  }
}
