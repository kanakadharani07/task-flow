rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    // Relaxed for onboarding: just check if signed in. If strictness is needed, use email_verified.
    function isVerified() { return isSignedIn(); }
    function isAdmin() { 
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.status in ['pending', 'in-progress', 'completed'] &&
             data.priority in ['low', 'medium', 'high'] &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.createdAt is timestamp &&
             data.updatedAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if (isOwner(userId) || isAdmin()) && 
                    incoming().role == existing().role && 
                    incoming().email == existing().email &&
                    incoming().createdAt == existing().createdAt;
    }

    match /tasks/{taskId} {
      // Pillar 8: Avoid get() in list rules. Only allow users to list their own tasks.
      // Admins can still 'get' individual tasks or perform queries through Admin Panel constraints.
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming());
      
      allow update: if isSignedIn() && 
                    (existing().userId == request.auth.uid || isAdmin()) &&
                    isValidTask(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'status', 'priority', 'dueDate', 'tags', 'category', 'assignedTo', 'attachments', 'updatedAt'])
                    );
      
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /notifications/{notificationId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isAdmin() || (isVerified() && incoming().userId == request.auth.uid); // Users can notify themselves, admins can notify anyone
      allow update: if isOwner(existing().userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(existing().userId);
    }
  }
}
